# Copy this file to .env and fill in real values before first use.
# Setup guide: https://guantou.site/archives/N2CmhISt
# After filling it in, run: npm run check-env && npm run check-cookies
# Do not commit .env. It contains full account credentials.

# Quark web Cookie used to save share links into your own Quark cloud drive.
QUARK_COOKIE=""

# Baidu Netdisk web Cookie used to save share links into your own Baidu cloud drive.
# It usually needs BDUSS/STOKEN from a logged-in pan.baidu.com browser session.
BAIDU_COOKIE=""

# OpenList fixed API token used for fs/list, fs/get, fs/copy, and task APIs.
OPENLIST_TOKEN=""

# OpenList service base URL.
OPENLIST_BASE_URL="http://127.0.0.1:5244"

# Default Quark cloud folder URL where share resources should be saved.
# Example: https://pan.quark.cn/list#/list/all/e38b48835b404f8092b2a7e5cc054b0d-%E6%9D%A5%E8%87%AA%EF%BC%9A%E5%88%86%E4%BA%AB
QUARK_DEFAULT_SAVE_URL=""

# Default Baidu Netdisk folder path or folder URL where share resources should be saved.
# This is a Baidu cloud-drive target, not a local filesystem path.
# Example: /我的资源/影视
# Example URL: https://pan.baidu.com/disk/main#/index?category=all&path=%2FNAS%E8%B5%84%E6%BA%90%E4%B8%8B%E8%BD%BD
BAIDU_DEFAULT_SAVE_PATH=""

# Default OpenList path backed by SMB/NAS storage for resource backup copies.
# Example: /影视资源备份/影视
OPENLIST_DEFAULT_COPY_DST_PATH=""
